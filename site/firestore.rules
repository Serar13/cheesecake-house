rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- Users / loyalty ----
    // Users can read/write their own profile. Admins can read/write any profile.
    // A user may never grant themselves the admin role.
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == 'customer');
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId
            && (!('role' in request.resource.data)
                || request.resource.data.role == resource.data.get('role', 'customer')));
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // ---- Admin-managed catalog (public read of active items) ----
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tables/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Reviews: public read of approved, anyone may submit (unapproved) ----
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.approved == false;
      allow update, delete: if isAdmin();
    }

    // ---- Orders: a user creates their own; admins manage all ----
    match /orders/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---- Reservations: a user creates their own; admins manage all ----
    match /reservations/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---- Offer / event requests: anyone may submit; admins manage ----
    match /offerRequests/{id} {
      allow read: if isAdmin();
      allow create: if request.resource.data.status == 'new';
      allow update, delete: if isAdmin();
    }
  }
}
